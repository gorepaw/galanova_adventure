{
  "name": "galanova_adventure",
  "version": "0.1.0",
  "private": true,
  "main": "electron-main.js",
  "scripts": {
    "build:engine": "tsc -p tsconfig.json && tsc -p tsconfig.gameplayloop.json",
    "watch:engine": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.gameplayloop.json --noEmit",
    "typecheck:ui": "tsc -p UI/tsconfig.json",
    "dev": "npm run build:engine && concurrently \"npm:watch:engine\" \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "npm run build:engine && vite build",
    "start": "npm run build:engine && electron .",
    "preview": "vite preview",
    "test": "npm run build:engine && node Testing/run_tests.js"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^9.1.0",
    "electron": "^33.4.11",
    "typescript": "^6.0.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  }
}
