{
  // Renderer (React + Vite) TypeScript config. Vite/esbuild does the actual
  // transpile; this config is for `tsc --noEmit` type-checking only. During the
  // .jsx→.tsx migration allowJs keeps the still-untyped .jsx files loadable while
  // checkJs:false means only .ts/.tsx are type-checked.
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": [],
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    // FULLY STRICT (noImplicitAny included). The IPC boundary is typed: props
    // flow from App's typed snapshot state (Engine/types/viewmodel.ts, produced
    // by electron-main getSnapshot() and consumed via the typed window.gameAPI in
    // src/gameAPI.d.ts). Genuinely-dynamic engine payloads are explicit `: any`.
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true
  },
  "include": ["src"]
}
