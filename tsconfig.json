{
  // Engine / Electron-main side (Node CommonJS). During the JS→TS migration each
  // converted .ts emits a .js NEXT TO IT (no outDir), so every existing runtime
  // require path keeps working and the not-yet-converted .js files load the
  // compiled output unchanged. allowJs is OFF so tsc never tries to emit a .js
  // over an input .js (TS5055). The generated .js/.js.map are gitignored.
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "node16",
    "moduleResolution": "node16",
    "types": ["node"]
  },
  // gameplayloop.ts is checked by tsconfig.gameplayloop.json (relaxed:
  // noImplicitAny/strictNullChecks off) because it's the ~3400-line combat core
  // over dynamically-shaped objects. It's excluded here so this config stays
  // FULLY strict; electron-main.ts and dungeons.ts pull its exports via require()
  // so it isn't dragged back into this strict program.
  "exclude": ["Engine/gameplayloop.ts"],
  "include": ["Engine/**/*.ts", "electron-main.ts", "preload.ts"]
}
